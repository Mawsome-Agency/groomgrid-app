# Database
DATABASE_URL="postgresql://user:password@localhost:5432/groomgrid"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Application URL (required for Stripe redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# Stripe Webhook Test Configuration (for E2E tests only)
# Generate with: openssl rand -hex 32
STRIPE_WEBHOOK_TEST_KEY="test_webhook_key_change_in_production"
ENABLE_TEST_WEBHOOK_BYPASS="false"

# Stripe Price IDs (from Stripe Dashboard > Products)
STRIPE_PRICE_SOLO="price_1TJDgnG4DfZ9Hko3qZUifmgo"
STRIPE_PRICE_SALON="price_1TJDguG4DfZ9Hko36faOkkXr"
STRIPE_PRICE_ENTERPRISE="price_1TJDgvG4DfZ9Hko3vLzhNLZ1"

# GA4 Measurement Protocol
# Measurement ID: GA4 Admin → Data Streams → [Web stream] → Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
# API Secret (REQUIRED for server-side event tracking — checkout, subscription, payment events):
# GA4 Admin → Data Streams → [Web stream] → Measurement Protocol API Secrets → Create
GA4_API_SECRET="your-ga4-api-secret"

# A/B Testing Custom Dimensions (optional, configure in GA4 Admin)
# NEXT_PUBLIC_GA4_CUSTOM_DIMENSION_AB_TEST="dimension1"

# Mailgun (email provider — replaces Resend)
MAILGUN_API_KEY="your-mailgun-api-key"
MAILGUN_DOMAIN="your-mailgun-sending-domain"
# Optional: override sender address (defaults to hello@{MAILGUN_DOMAIN})
# MAILGUN_FROM_EMAIL="GroomGrid <hello@yourdomain.com>"

# Sentry
SENTRY_DSN="your-sentry-dsn"
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="groomgrid"
