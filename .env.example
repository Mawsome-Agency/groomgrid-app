# GroomGrid App Environment Variables
# Copy this file to .env.local and fill in your values.

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/groomgrid_dev

# NextAuth (required)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Stripe (required)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_SALON=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Google Analytics (required)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4 Measurement Protocol secret — for server-side event tracking (webhooks, API routes)
# Generate at: GA4 Admin → Data Streams → [stream] → Measurement Protocol → Create secret
GA4_API_SECRET=

# App URL (required)
NEXT_PUBLIC_APP_URL=https://getgroomgrid.com

# Email (required)
RESEND_API_KEY=re_...

# Cron (required for drip emails)
CRON_SECRET=your-cron-secret
